# GameAI Analytics 환경 변수 설정
# 이 파일을 .env로 복사하여 사용하세요: cp .env.example .env

# ─── API 설정 ───
GAMEAI_API_KEYS=dev-key-gameai-2024,prod-key-change-me
API_HOST=0.0.0.0
API_PORT=8000

# ─── PostgreSQL ───
POSTGRES_USER=gameai
POSTGRES_PASSWORD=gameai_password
POSTGRES_DB=gameai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://gameai:gameai_password@localhost:5432/gameai

# ─── Redis ───
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# ─── JWT 인증 ───
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_EXPIRE_MINUTES=30

# ─── Rate Limiting ───
RATE_LIMIT=60/minute

# ─── CORS ───
CORS_ORIGINS=http://localhost:8501,http://localhost:3000

# ─── Logging ───
LOG_LEVEL=INFO
LOG_FORMAT=json

# ─── MLflow ───
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── 모델 설정 ───
MODEL_PATH=models/best_model.joblib
RANDOM_STATE=42
TEST_SIZE=0.2

# ─── ONNX (선택) ───
USE_ONNX=false
