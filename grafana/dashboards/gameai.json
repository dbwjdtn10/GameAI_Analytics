{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Prediction Requests / min",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(gameai_prediction_requests_total[1m]) * 60",
          "legendFormat": "{{endpoint}} - {{risk_level}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqpm" }
      }
    },
    {
      "title": "Prediction Latency (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(gameai_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p95 {{endpoint}}"
        },
        {
          "expr": "histogram_quantile(0.50, rate(gameai_prediction_latency_seconds_bucket[5m]))",
          "legendFormat": "p50 {{endpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "High Risk Users Detected",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(increase(gameai_high_risk_users_total[1h]))",
          "legendFormat": "Last 1h"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Model Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "gameai_model_loaded",
          "legendFormat": "Model Loaded"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "options": { "0": { "text": "NOT LOADED", "color": "red" } }, "type": "value" },
            { "options": { "1": { "text": "LOADED", "color": "green" } }, "type": "value" }
          ]
        }
      }
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(gameai_cache_hits_total[5m])) / (sum(rate(gameai_cache_hits_total[5m])) + sum(rate(gameai_cache_misses_total[5m])))",
          "legendFormat": "Hit Rate"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "percentunit", "max": 1, "min": 0 }
      }
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "rate(gameai_prediction_errors_total[5m]) * 60",
          "legendFormat": "{{error_type}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "errpm" }
      }
    },
    {
      "title": "HTTP Request Duration (FastAPI Instrumentator)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, handler))",
          "legendFormat": "p95 {{handler}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Batch Size Distribution",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(gameai_batch_prediction_size_bucket[5m]))",
          "legendFormat": "Median batch size"
        },
        {
          "expr": "histogram_quantile(0.95, rate(gameai_batch_prediction_size_bucket[5m]))",
          "legendFormat": "p95 batch size"
        }
      ]
    },
    {
      "title": "Model Inference Total",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "targets": [
        {
          "expr": "rate(gameai_model_inference_total[5m]) * 60",
          "legendFormat": "{{model_type}} inferences/min"
        }
      ]
    },
    {
      "title": "Data Drift Ratio",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "targets": [
        {
          "expr": "gameai_drift_ratio",
          "legendFormat": "Drift Ratio"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.2 },
              { "color": "red", "value": 0.5 }
            ]
          }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["gameai", "ml", "monitoring"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "GameAI Analytics - ML Monitoring",
  "uid": "gameai-ml-monitoring"
}
